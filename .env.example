# Server
PORT=2567
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PUBLIC_CLIENT_URL=http://localhost:5173
MAX_PLAYERS=12
DEMO_MAX_PLAYERS=8
ROOM_TICK_RATE=30
ROOM_PATCH_RATE=20
ROOM_AUTO_START_SECONDS=12
ENABLE_BOTS=false
LOG_LEVEL=info

# Client
VITE_WS_URL=ws://localhost:2567
VITE_HTTP_API_URL=http://localhost:2567
VITE_BUILD_VERSION=local
VITE_DEBUG=true

